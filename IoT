def main():
    manager = IoTManager()
    iterations = 15  # Кількість автоматичних кроків моніторингу
    
    print("Ініціалізація системи автоматичного моніторингу IoT...")
    time.sleep(1)

    if RICH_OK:
        try:
            with Live(console=console, refresh_per_second=1) as live:
                for _ in range(iterations):
                    manager.update_all()
                    
                    layout = Layout()
                    layout.split_column(
                        Layout(build_sensor_table(manager), name="table", ratio=3),
                        Layout(build_events_panel(manager), name="events", ratio=1)
                    )
                    live.update(layout)
                    time.sleep(2)
        except KeyboardInterrupt:
            pass
    else:
        # Спрощений консольний текст, якщо Rich відсутній
        for i in range(iterations):
            manager.update_all()
            print(f"\n--- Крок моніторингу {i+1}/{iterations} ({datetime.now().strftime('%H:%M:%S')}) ---")
            for s in manager.sensors:
                print(f"Датчик: {s.name:15} | Значення: {s.formatted_value:10} | Статус: {s.status}")
            time.sleep(2)

    # Експорт фінальних звітів та запуск візуалізації
    manager.save_json_report()
    print(f"\n[+] Дані успішно залоговано в '{manager.csv_filename}'")
    print(f"[+] Фінальний аналітичний звіт збережено в '{manager.json_filename}'")
    
    plot_charts(manager)
    print("Роботу системи моніторингу завершено успішно.")

if __name__ == "__main__":
    main()
