class Sensor:
    def __init__(self, config):
        self.id = config["id"]
        self.name = config["name"]
        self.location = config["location"]
        self.room = config["room"]
        self.unit = config["unit"]
        self.min_val = config["min"]
        self.max_val = config["max"]
        self.warn_threshold = config["warn"]
        self.crit_threshold = config["crit"]
        
        self.current_value = (self.min_val + self.max_val) / 2
        self.history = deque(maxlen=MAX_HISTORY)
        self.timestamps = deque(maxlen=MAX_HISTORY)
        
        # Початковий розігрів історії (20 точок) для стабільної аналітики
        base_time = datetime.now() - timedelta(minutes=40)
        for i in range(20):
            self.simulate_reading()
            self.timestamps.append(base_time + timedelta(minutes=i*2))

    def simulate_reading(self):
        """Генерація значень з випадковими флуктуаціями та аномаліями"""
        # Малі випадкові коливання
        change = random.uniform(-2, 2) if self.id != "co2_c" else random.uniform(-30, 30)
        self.current_value += change
        
        # Симуляція випадкових аномалій (8% ймовірність)
        if random.random() < 0.08:
            anomaly_direction = 1 if random.random() > 0.3 else -1
            anomaly_spike = (self.max_val - self.min_val) * 0.25 * anomaly_direction
            self.current_value += anomaly_spike

        # Контроль фізичних меж датчика
        self.current_value = max(self.min_val, min(self.max_val, self.current_value))
        self.history.append(self.current_value)
        self.timestamps.append(datetime.now())

    @property
    def status(self):
        if self.current_value >= self.crit_threshold:
            return "Критично"
        elif self.current_value >= self.warn_threshold:
            return "Увага"
        return "Норма"

    @property
    def formatted_value(self):
        return f"{self.current_value:.1f} {self.unit}"


class AutomationRule:
    def __init__(self, sensor_id, condition_type, threshold, action_name):
        self.sensor_id = sensor_id
        self.condition_type = condition_type  # 'gt' (більше) або 'lt' (менше)
        self.threshold = threshold
        self.action_name = action_name

    def check(self, value):
        if self.condition_type == "gt" and value >= self.threshold:
            return True
        if self.condition_type == "lt" and value <= self.threshold:
            return True
        return False


class IoTManager:
    def __init__(self):
        self.sensors = [Sensor(cfg) for cfg in SENSOR_CONFIGS]
        self.rules = [
            AutomationRule("temp_a", "gt", 75, "Ввімкнути резервне охолодження сервера!"),
            AutomationRule("smoke_b", "gt", 30, "Пожежна тривога на складі! Активація витяжки."),
            AutomationRule("co2_c", "gt", 1400, "Перевищено рівень CO2. Ввімкнути примусову вентиляцію офісу.")
        ]
        self.event_log = []
        self._last_notified = {}
        self.csv_filename = "iot_data_log.csv"
        self.json_filename = "iot_data_log.json"
        
        # Створення заголовків CSV файлу, якщо він новий
        if not os.path.exists(self.csv_filename):
            try:
                with open(self.csv_filename, 'w', newline='', encoding='utf-8') as f:
                    writer = csv.writer(f)
                    writer.writerow(["Час", "ID Датчика", "Назва", "Значення", "Статус", "Тренд"])
            except Exception:
                pass

    def update_all(self):
        """Оновлення станів усіх датчиків, перевірка правил та запис у CSV"""
        for sensor in self.sensors:
            sensor.simulate_reading()
            trend_text, _ = Analytics.trend_analysis(sensor.history)
            
            # Запис у CSV файл
            try:
                with open(self.csv_filename, 'a', newline='', encoding='utf-8') as f:
                    writer = csv.writer(f)
                    writer.writerow([
                        datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
                        sensor.id, sensor.name, round(sensor.current_value, 2),
                        sensor.status, trend_text
                    ])
            except Exception:
                pass

        self._check_rules()

    def _check_rules(self):
        """Внутрішня перевірка правил автоматизації"""
        for rule in self.rules:
            sensor = next((s for s in self.sensors if s.id == rule.sensor_id), None)
            if sensor and rule.check(sensor.current_value):
                # Блокування дублювання однакових сповіщень поспіль
                if self._last_notified.get(rule.sensor_id) != rule.action_name:
                    timestamp = datetime.now().strftime("%H:%M:%S")
                    msg = f"[{timestamp}] [АВТОМАТИКА] {sensor.name} ({sensor.formatted_value}) -> {rule.action_name}"
                    self.event_log.append(msg)
                    self._last_notified[rule.sensor_id] = rule.action_name
            else:
                if sensor and self._last_notified.get(rule.sensor_id) == rule.action_name:
                    # Скидання блокування, якщо стан повернувся до норми
                    timestamp = datetime.now().strftime("%H:%M:%S")
                    self.event_log.append(f"[{timestamp}] [СИСТЕМА] {sensor.name} нормалізувався.")
                    self._last_notified[rule.sensor_id] = None

    def save_json_report(self):
        """Експорт фінального звіту у JSON формат"""
        report = {
            "metadata": {
                "generated_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
                "total_sensors": len(self.sensors)
            },
            "snapshots": []
        }
        for s in self.sensors:
            trend, _ = Analytics.trend_analysis(s.history)
            forecast_vals = Analytics.forecast(list(s.history), steps=3)
            report["snapshots"].append({
                "id": s.id,
                "name": s.name,
                "location": f"{s.location} ({s.room})",
                "last_value": round(s.current_value, 2),
                "unit": s.unit,
                "status": s.status,
                "current_trend": trend,
                "short_forecast_3h": [round(v, 2) for v in forecast_vals]
            })
        
        try:
            with open(self.json_filename, 'w', encoding='utf-8') as f:
                json.dump(report, f, indent=4, ensure_ascii=False)
        except Exception as e:
            print(f"Помилка експорту JSON: {e}")

