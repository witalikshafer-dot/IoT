class Analytics:
    @staticmethod
    def linear_regression(y_data):
        """Обчислення лінійного тренду (коефіцієнт нахилу)"""
        n = len(y_data)
        if n < 2:
            return 0.0
        x = list(range(n))
        sum_x = sum(x)
        sum_y = sum(y_data)
        sum_xx = sum(i*i for i in x)
        sum_xy = sum(x[i] * y_data[i] for i in range(n))
        
        denominator = (n * sum_xx - sum_x * sum_x)
        if denominator == 0:
            return 0.0
        slope = (n * sum_xy - sum_x * sum_y) / denominator
        return slope

    @staticmethod
    def holt_smoothing(data, alpha=0.3, beta=0.1):
        """Експоненціальне згладжування Хольта для аналізу тенденцій"""
        if not data:
            return []
        result = [data[0]]
        level = data[0]
        trend = data[1] - data[0] if len(data) > 1 else 0
        
        for i in range(1, len(data)):
            val = data[i]
            last_level, level = level, alpha * val + (1 - alpha) * (level + trend)
            trend = beta * (level - last_level) + (1 - beta) * trend
            result.append(level + trend)
        return result

    @classmethod
    def forecast(cls, data, steps=3, alpha=0.3, beta=0.1):
        """Прогнозування значень часового ряду на кілька кроків наперед"""
        if len(data) < 2:
            return [data[-1]] * steps if data else [0.0] * steps
        
        level = data[0]
        trend = data[1] - data[0]
        
        for i in range(1, len(data)):
            val = data[i]
            last_level, level = level, alpha * val + (1 - alpha) * (level + trend)
            trend = beta * (level - last_level) + (1 - beta) * trend
            
        return [level + (k * trend) for k in range(1, steps + 1)]

    @classmethod
    def trend_analysis(cls, history):
        """Повертає текстовий та графічний індикатор тренду"""
        if len(history) < 5:
            return "Стабільний ─", 0.0
        recent = list(history)[-10:]
        slope = cls.linear_regression(recent)
        
        if slope > 0.05:
            return "Зростає ▲", slope
        elif slope < -0.05:
            return "Спадає ▼", slope
        else:
            return "Стабільний ─", slope

