def build_sensor_table(manager: IoTManager) -> Table:
    """Генерація інтерактивної таблиці за допомогою Rich"""
    table = Table(title="📊 Моніторинг IoT Sensor Network (В режимі Live)", box=box.ROUNDED, expand=True)
    table.add_column("ID", justify="center", style="cyan")
    table.add_column("Метрика / Датчик", style="bold white")
    table.add_column("Локація", style="italic list")
    table.add_column("Поточне значення", justify="right")
    table.add_column("Статус", justify="center")
    table.add_column("Математичний Тренд", justify="center")
    table.add_column("Прогноз (через 3 год)", justify="right", style="magenta")

    for s in manager.sensors:
        status_str = s.status
