        self._fc_cb.current(0)
        self._fc_cb.pack(side="left", padx=4)

        ttk.Label(ctrl, text=" Період: ").pack(side="left", padx=5)
        self._fc_horizon_var = tk.StringVar(value="6")
        ttk.Combobox(ctrl, textvariable=self._fc_horizon_var, values=["3","6","12","24"], width=5, state="readonly").pack(side="left")

