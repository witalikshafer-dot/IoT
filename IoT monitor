    def _render_dashboard(self):
        t = self.theme
        for w in self._metrics_frame.winfo_children():
            w.destroy()
        
        self.root.update_idletasks()
        w_width = self._metrics_frame.winfo_width()
        if w_width < 200: w_width = 1150
        cols = max(1, w_width // 145)

        for i, s in enumerate(self.sensors):
            card = ttk.Frame(self._metrics_frame, style="Card.TFrame", padding=8)
            card.grid(row=i//cols, column=i%cols, padx=4, pady=4, sticky="nsew")
            
            st = sensor_status(s["current"], s)
            stc = status_color(s["current"], s, t)
            val_str = ("ON" if s["current"] >= 1 else "OFF") if s["unit"] == "" else f"{s['current']}"
            
            ttk.Label(card, text=s["name"], style="CardTitle.TLabel").pack(anchor="w")
            ttk.Label(card, text=s["location"], style="CardSub.TLabel").pack(anchor="w")
            ttk.Label(card, text=f"{val_str} {s['unit']}", style="CardValue.TLabel").pack(anchor="w", pady=2)
            
            delta = round(s["current"] - s["prev"], 2)
            sign = "▲" if delta > 0 else ("▼" if delta < 0 else "—")
            dcol = t["err"] if (delta > 0 and s["unit"] != "") else t["ok"]
            
            lbl_delta = tk.Label(card, text=f"{sign} {abs(delta)}", font=("Courier New", 8, "bold"), fg=dcol, bg=t["surface"])
            lbl_delta.pack(anchor="w")
            
            lbl_st = tk.Label(card, text=st.upper(), font=("Courier New", 8, "bold"), fg=stc, bg=t["surface"])
            lbl_st.pack(anchor="w", pady=(2,0))

        sel = self._sensor_var.get() or self.sensors[0]["name"]
        s = next((x for x in self.sensors if x["name"] == sel), self.sensors[0])
        ax = self._main_ax
        ax.clear()
        
        ax.plot(list(s["history"]), color=s["color"], linewidth=2, marker="o", markersize=3)
        if s["unit"] != "":
            ax.axhline(s["warn"], color=t["warn"], linestyle="--", linewidth=1, alpha=0.8, label="Увага")
            ax.axhline(s["err"],  color=t["err"],  linestyle="--", linewidth=1, alpha=0.8, label="Критично")
            ax.legend(fontsize=8, facecolor=t["chart_bg"], labelcolor=t["text2"], loc="upper left")
            
        ax.set_facecolor(t["chart_bg"])
        self._main_fig.patch.set_facecolor(t["chart_bg"])
        ax.tick_params(colors=t["text2"], labelsize=8)
        for spine in ax.spines.values(): spine.set_edgecolor(t["border"])
        ax.set_title(f"Аналіз змін: {s['name']} ({s['unit']})", color=t["text"], fontsize=10, fontfamily="monospace", weight="bold")
        self._main_canvas.draw()

        for w in self._sensor_list_frame.winfo_children(): w.destroy()
        for s in self.sensors:
            row = ttk.Frame(self._sensor_list_frame, style="Card.TFrame")
            row.pack(fill="x", pady=2, padx=4)
            
            val_str = ("ON" if s["current"] >= 1 else "OFF") if s["unit"] == "" else f"{s['current']} {s['unit']}"
            
            tk.Label(row, text=f"■ {s['name']}", font=("Courier New", 9, "bold"), fg=s["color"], bg=t["surface"]).pack(side="left", padx=4)
            ttk.Label(row, text=s["location"], style="CardSub.TLabel").pack(side="left", padx=10)
            ttk.Label(row, text=val_str, font=("Courier New", 9, "bold"), background=t["surface"]).pack(side="right", padx=10)

        for w in self._alerts_frame.winfo_children(): w.destroy()
        any_alert = False
        for s in self.sensors:
            st = sensor_status(s["current"], s)
            if st in ("Критично", "Увага", "Спрацював"):
                any_alert = True
                stc = status_color(s["current"], s, t)
                bg_alert = t["err_bg"] if st == "Критично" else t["warn_bg"]
                val_str = ("ON" if s["current"] >= 1 else "OFF") if s["unit"] == "" else f"{s['current']} {s['unit']}"
                
                f_alert = tk.Frame(self._alerts_frame, bg=bg_alert, relief="flat", bd=0)
                f_alert.pack(fill="x", padx=5, pady=2)
                
                icon = "" if st == "Критично" else ""
                tk.Label(f_alert, text=f"{icon} {s['name'].upper()} у [{s['room']}]: {val_str} — {st.upper()}",
                         font=("Courier New", 9, "bold"), fg=stc, bg=bg_alert, anchor="w").pack(fill="x", padx=5, pady=4)
        if not any_alert:
            f_ok = tk.Frame(self._alerts_frame, bg=t["ok_bg"])
            f_ok.pack(fill="x", padx=5, pady=5)
            tk.Label(f_ok, text="✓ СИСТЕМА ПРАЦЮЄ В ШТАТНОМУ РЕЖИМІ. ПОМИЛОК НЕМАЄ", font=("Courier New", 9, "bold"), fg=t["ok"], bg=t["ok_bg"]).pack(pady=6)

    def _build_compare(self):
        frame = ttk.Frame(self.content)
        self.pages["compare"] = frame

        ttk.Label(frame, text="Порівняльний аналіз роботи датчиків", style="Header.TLabel").pack(pady=8, anchor="w")

        self._cmp_fig = Figure(figsize=(8, 3.8), dpi=95)
        self._cmp_ax  = self._cmp_fig.add_subplot(111)
        canvas = FigureCanvasTkAgg(self._cmp_fig, frame)
        canvas.get_tk_widget().pack(fill="both", expand=True, pady=4)
        self._cmp_canvas = canvas

        self._room_frame = ttk.LabelFrame(frame, text=" Агреговані дані по локаціях ")
        self._room_frame.pack(fill="x", pady=6)

    def _render_compare(self):
        t = self.theme
        ax = self._cmp_ax
        ax.clear()
        hours = list(range(24))
        for s in self.sensors:
            if s["unit"] == "": continue
            ax.plot(hours, s["series"], color=s["color"], linewidth=1.5, label=s["name"], alpha=0.8)
            
        ax.set_facecolor(t["chart_bg"])
        self._cmp_fig.patch.set_facecolor(t["chart_bg"])
        ax.tick_params(colors=t["text2"], labelsize=8)
        for sp in ax.spines.values(): sp.set_edgecolor(t["border"])
        ax.legend(fontsize=8, facecolor=t["chart_bg"], labelcolor=t["text2"])
        ax.set_title("Добова нормалізована динаміка", color=t["text"], fontfamily="monospace", weight="bold")
        self._cmp_canvas.draw()

        for w in self._room_frame.winfo_children(): w.destroy()
        rooms = {}
        for s in self.sensors:
            if s["unit"] == "": continue
            rooms.setdefault(s["room"], []).append(s["current"])
            
        for room, vals in rooms.items():
            avg = round(sum(vals)/len(vals), 1)
            row = ttk.Frame(self._room_frame, style="Card.TFrame", padding=4)
            row.pack(fill="x", pady=2, padx=5)
            ttk.Label(row, text=f" {room}:", width=20, style="CardTitle.TLabel").pack(side="left")
            ttk.Label(row, text=f"Середній показник середовища: {avg}", background=t["surface"]).pack(side="left", padx=10)

    def _build_forecast(self):
        frame = ttk.Frame(self.content)
        self.pages["forecast"] = frame

        ctrl = ttk.Frame(frame)
        ctrl.pack(fill="x", pady=8)
        
        ttk.Label(ctrl, text="Датчик: ").pack(side="left")
        self._fc_sensor_var = tk.StringVar()
