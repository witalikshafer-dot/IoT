        self._render_rules()

    def _check_rules(self):
        for r in self.rules:
            s = next((x for x in self.sensors if x["name"] == r["sensor"]), None)
            if not s: continue
            v = s["current"]
            triggered = (r["op"] == ">" and v > r["val"]) or \
                        (r["op"] == "<" and v < r["val"]) or \
                        (r["op"] == "=" and abs(v - r["val"]) < 0.1)
            if triggered:
                self.rule_log.insert(0, dict(
                    time=datetime.now().strftime("%H:%M:%S"),
                    rule=f"{r['sensor']} {r['op']} {r['val']}",
                    value=f"{v} {s['unit']}",
                    action=f"{r['action']}: {r['msg']}"
                ))
                if r["action"] == "alarm": self.root.bell()

        if hasattr(self, "_rule_tree") and self._rule_tree.winfo_exists():
            for row in self._rule_tree.get_children(): self._rule_tree.delete(row)
            for row in self.rule_log[:40]:
                self._rule_tree.insert("", "end", values=(row["time"], row["rule"], row["value"], row["action"]))

