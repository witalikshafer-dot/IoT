    def _render_forecast(self):
        t = self.theme
        sel = self._fc_sensor_var.get()
        s = next((x for x in self.sensors if x["name"] == sel), self.sensors[0])
        horizon = int(self._fc_horizon_var.get())
        method  = self._fc_method_var.get()

        hist = s["series"] 
        def forecast_linear(data, n):
            x = np.arange(len(data))
            m, b = np.polyfit(x, data, 1)
            return [round(m*(len(data)+i)+b, 2) for i in range(n)]
        def forecast_ma(data, n, w=5):
            last = np.mean(data[-w:])
            return [round(last + (np.random.randn()*0.15), 2) for _ in range(n)]
        def forecast_exp(data, n, a=0.3):
            v = data[-1]
            out = []
            for _ in range(n):
                v = a*data[-1] + (1-a)*v
                out.append(round(v, 2))
            return out
        def forecast_holt(data, n, a=0.3, b=0.1):
            l, tr = data[-1], data[-1]-data[-2] if len(data)>1 else 0
            out = []
            for _ in range(n):
                l2 = a*data[-1] + (1-a)*(l+tr)
                tr = b*(l2-l) + (1-b)*tr
                l = l2
                out.append(round(l+tr, 2))
            return out

        fc_map = {"linear": forecast_linear, "ma": forecast_ma, "exp": forecast_exp, "holt": forecast_holt}
        predicted = fc_map[method](hist, horizon)

        ax = self._fc_ax
        ax.clear()
        ax.plot(list(range(len(hist))), hist, color=s["color"], linewidth=2, label="Реальні дані (Факт)")
        ax.plot(list(range(len(hist), len(hist)+horizon)), predicted, color="#7f77dd", linewidth=2, linestyle="--", marker="o", label="Прогнозований тренд")
        ax.set_facecolor(t["chart_bg"])
        self._fc_fig.patch.set_facecolor(t["chart_bg"])
        ax.tick_params(colors=t["text2"], labelsize=8)
        for sp in ax.spines.values(): sp.set_edgecolor(t["border"])
        ax.legend(fontsize=8, facecolor=t["chart_bg"], labelcolor=t["text2"])
        self._fc_canvas.draw()

        for w in self._fc_table_frame.winfo_children(): w.destroy()
        for i, v in enumerate(predicted):
            stc = status_color(v, s, t)
            row = tk.Frame(self._fc_table_frame, bg=t["surface"])
            row.pack(fill="x", pady=2, padx=10)
            
            tk.Label(row, text=f"через {i+1} год. ➔", font=("Courier New", 9), fg=t["text2"], bg=t["surface"]).pack(side="left")
            tk.Label(row, text=f"{v} {s['unit']}", font=("Courier New", 9, "bold"), fg=t["text"], bg=t["surface"]).pack(side="left", padx=15)
            tk.Label(row, text=sensor_status(v,s).upper(), font=("Courier New", 8, "bold"), fg=stc, bg=t["surface"]).pack(side="right")

