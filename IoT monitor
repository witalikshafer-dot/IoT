    def _export_csv(self):
        path = filedialog.asksaveasfilename(defaultextension=".csv", filetypes=[("CSV","*.csv")])
        if not path: return
        with open(path, "w", newline="", encoding="utf-8-sig") as f:
            w = csv.writer(f)
            w.writerow(["Час","Датчик","Місце","Значення","Одиниця","Статус"])
            for r in self.data_log: w.writerow([r["time"],r["name"],r["location"],r["value"],r["unit"],r["status"]])
        messagebox.showinfo("Експорт", "Дані збережено.")

    def _export_json(self):
        path = filedialog.asksaveasfilename(defaultextension=".json", filetypes=[("JSON","*.json")])
        if not path: return
        with open(path, "w", encoding="utf-8") as f: json.dump(self.data_log, f, ensure_ascii=False, indent=2)
        messagebox.showinfo("Експорт", "Дані збережено.")

